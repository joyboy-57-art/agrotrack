{
  "name": "agrotrack",
  "version": "1.0.0",
  "private": true,
  "description": "Farm Equipment Rental & Asset Management System",
  "main": "server/server.js",
  "workspaces": [
    "server",
    "frontend",
    "client"
  ],
  "scripts": {
    "start": "node server/server.js",
    "server": "cd server && npm start",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "build": "cd frontend && npm run build && cd ../client && npm run build",
    "install-all": "npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}